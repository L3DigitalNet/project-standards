{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"content": { "type": "string" },
		"file": { "type": "string" },
		"selector": { "type": "string" },
		"kind": { "enum": ["id", "section", "appendix", "heading"] },
		"found": { "type": "boolean" },
		"markdown": { "type": ["string", "null"] },
		"prefix": { "type": "string" },
		"next_id": { "type": "string" }
	},
	"required": ["content"]
}
