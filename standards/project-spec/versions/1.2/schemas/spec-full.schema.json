{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "Project Specification Full Profile",
	"type": "object",
	"additionalProperties": false,
	"$defs": {
		"spec_id": { "type": "string", "pattern": "^SPEC-[0-9A-Z]{4}$" },
		"optional_spec_id": {
			"anyOf": [{ "$ref": "#/$defs/spec_id" }, { "type": "null" }]
		},
		"string_list": {
			"type": "array",
			"items": { "type": "string" },
			"uniqueItems": true
		}
	},
	"properties": {
		"spec_id": { "$ref": "#/$defs/spec_id" },
		"title": { "type": "string", "minLength": 1 },
		"status": { "enum": ["draft", "review", "approved", "superseded"] },
		"profile": { "const": "full" },
		"owner": { "type": "string", "minLength": 1 },
		"implementer": { "type": "string", "minLength": 1 },
		"created": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
		"last_reviewed": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
		"supersedes": { "$ref": "#/$defs/optional_spec_id" },
		"superseded_by": { "$ref": "#/$defs/optional_spec_id" },
		"related": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"adrs": { "$ref": "#/$defs/string_list" },
				"tickets": { "$ref": "#/$defs/string_list" },
				"repositories": { "$ref": "#/$defs/string_list" },
				"prior_specs": { "$ref": "#/$defs/string_list" }
			},
			"required": ["adrs", "tickets", "repositories", "prior_specs"]
		}
	},
	"required": [
		"spec_id",
		"title",
		"status",
		"profile",
		"owner",
		"implementer",
		"created",
		"last_reviewed",
		"supersedes",
		"superseded_by",
		"related"
	]
}
